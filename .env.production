# Production Environment Variables
# This file is used when building for production (npm run build)
# 
# IMPORTANT: Configure these same variables in Render Dashboard:
# Settings → Environment → Add Environment Variable

# Backend API URL - Your Render backend URL (no trailing slash)
# Set this ALSO in the Render dashboard: Environment → VITE_API_URL
VITE_API_URL=https://donation-platform-api.onrender.com
